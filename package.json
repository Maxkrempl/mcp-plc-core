{
  "name": "mcp-plc-core",
  "version": "1.0.0",
  "description": "MCP Server core for industrial PLC communication — bring your own adapter",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-plc": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "example:modbus": "tsx examples/modbus-adapter.ts",
    "example:s7": "tsx examples/s7-adapter.ts"
  },
  "keywords": [
    "mcp",
    "plc",
    "industrial",
    "automation",
    "siemens",
    "modbus",
    "s7",
    "opc-ua",
    "scada"
  ],
  "author": "HD WebDesign",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "modbus-serial": ">=8.0.0",
    "nodes7": ">=0.3.0"
  },
  "peerDependenciesMeta": {
    "nodes7": {
      "optional": true
    },
    "modbus-serial": {
      "optional": true
    }
  }
}
